{
  "name": "AgentConfig",
  "type": "object",
  "properties": {
    "agent_name": {
      "type": "string",
      "default": "Emil"
    },
    "business_goal": {
      "type": "string",
      "description": "Primary business objective"
    },
    "strategy": {
      "type": "string",
      "description": "Business strategy description"
    },
    "approval_mode": {
      "type": "string",
      "enum": [
        "auto",
        "ask_first",
        "ask_if_money",
        "ask_if_external",
        "ask_if_destructive"
      ],
      "default": "ask_first",
      "description": "When Emil should ask before acting"
    },
    "whatsapp_rules": {
      "type": "string",
      "enum": [
        "urgent_only",
        "task_complete",
        "money_events",
        "daily_summary",
        "session_summary",
        "all"
      ],
      "default": "daily_summary",
      "description": "When Emil can message you on WhatsApp"
    },
    "max_messages_per_hour": {
      "type": "number",
      "default": 3,
      "description": "Max WhatsApp messages per hour (anti-spam)"
    },
    "payout_method": {
      "type": "string",
      "enum": [
        "bank_transfer",
        "paypal",
        "crypto",
        "other"
      ],
      "default": "bank_transfer"
    },
    "payout_details": {
      "type": "string"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "auto_mode": {
      "type": "boolean",
      "default": false,
      "description": "Allow agent to act autonomously"
    }
  },
  "required": [
    "agent_name"
  ]
}