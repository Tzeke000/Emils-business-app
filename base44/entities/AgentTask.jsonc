{
  "name": "AgentTask",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Task title"
    },
    "description": {
      "type": "string",
      "description": "Detailed task description"
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "active",
        "blocked",
        "waiting_on_user",
        "completed",
        "failed",
        "abandoned",
        "retried"
      ],
      "default": "queued"
    },
    "category": {
      "type": "string",
      "enum": [
        "research",
        "content_creation",
        "outreach",
        "development",
        "marketing",
        "analytics",
        "desktop_control",
        "other"
      ],
      "default": "other"
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ],
      "default": "medium"
    },
    "source": {
      "type": "string",
      "enum": [
        "emil_auto",
        "user_request",
        "scheduled",
        "retry",
        "dependency"
      ],
      "default": "user_request",
      "description": "Who/what created this task"
    },
    "started_at": {
      "type": "string",
      "format": "date-time",
      "description": "When work actually began"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time",
      "description": "When task finished"
    },
    "blocker_reason": {
      "type": "string",
      "description": "Why the task is blocked"
    },
    "blocked_by_type": {
      "type": "string",
      "enum": [
        "approval",
        "missing_credential",
        "external_service",
        "user_response",
        "dependency",
        "rate_limit",
        "other"
      ],
      "description": "Structured blocker category"
    },
    "dependency_ids": {
      "type": "string",
      "description": "Comma-separated IDs of tasks this depends on"
    },
    "parent_task_id": {
      "type": "string",
      "description": "ID of the task this was retried from"
    },
    "original_task_id": {
      "type": "string",
      "description": "ID of the original task in a retry chain"
    },
    "retry_count": {
      "type": "number",
      "default": 0,
      "description": "How many times this task lineage has been retried"
    },
    "result_summary": {
      "type": "string",
      "description": "What happened when done"
    },
    "artifact_link": {
      "type": "string",
      "description": "URL or path to output artifact"
    },
    "next_step": {
      "type": "string",
      "description": "What should happen after this task"
    },
    "session_id": {
      "type": "string",
      "description": "Which work session this belongs to"
    },
    "requires_approval": {
      "type": "boolean",
      "default": false,
      "description": "Whether user must approve before execution"
    },
    "approval_status": {
      "type": "string",
      "enum": [
        "not_needed",
        "pending",
        "approved",
        "rejected"
      ],
      "default": "not_needed"
    },
    "revenue_generated": {
      "type": "number",
      "default": 0,
      "description": "Revenue from this task in USD"
    },
    "outcome_score": {
      "type": "number",
      "description": "0-10 score of how well the task went"
    },
    "why_it_worked": {
      "type": "string",
      "description": "What contributed to success"
    },
    "why_it_failed": {
      "type": "string",
      "description": "What went wrong and lessons learned"
    }
  },
  "required": [
    "title"
  ]
}